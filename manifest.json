{
  "manifest_version": 3,
  "name": "AutoAlias",
  "version": "0.1.1",
  "description": "Generate email aliases using the current domain.",
  "action": {
    "default_title": "AutoAlias",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["toggleIcon.js"]
    }
  ],
  "permissions": ["clipboardWrite", "activeTab", "storage", "offscreen", "notifications"],
  "commands": {
    "copy-alias": {
      "suggested_key": {
        "default": "Alt+Shift+A",
        "mac": "Alt+Shift+A"
      },
      "description": "Copy generated alias"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
